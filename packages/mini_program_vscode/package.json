        "icon": "$(file-code)"
      },
      {
        "command": "miniProgramTools.setupHostApp",
        "title": "MiniProgram: Setup Host App",
        "icon": "$(package)"
      },
      {
        "command": "miniProgramTools.addMiniProgramToHost",
        "title": "MiniProgram: Add MiniProgram to Host",
        "icon": "$(add)"
      },
      {
        "command": "miniProgramTools.runHostSmokeTest",
