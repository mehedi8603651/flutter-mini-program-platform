  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js",
    "package:vsix": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
