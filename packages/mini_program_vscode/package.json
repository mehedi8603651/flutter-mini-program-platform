        "icon": "$(output)"
      },
      {
        "command": "miniProgramTools.copyAwsBackendHostCommand",
        "title": "MiniProgram: Copy AWS Backend Host Command",
        "icon": "$(copy)"
      },
      {
        "command": "miniProgramTools.copyPublisherBackendUrls",
        "title": "MiniProgram: Copy Publisher Backend URLs",
        "icon": "$(copy)"
      },
      {
        "command": "miniProgramTools.copyMockBackendHostCommand",
