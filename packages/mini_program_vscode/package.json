        "icon": "$(new-folder)"
      },
      {
        "command": "miniProgramTools.publishMiniProgramToAws",
        "title": "MiniProgram: Publish MiniProgram to AWS",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "miniProgramTools.preparePartnerHandoff",
