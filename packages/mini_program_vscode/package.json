{
  "name": "mini-program-tools",
  "displayName": "MiniProgram Tools",
  "description": "Native VS Code sidebar for MiniProgram CLI workflows.",
  "version": "0.1.21",
  "publisher": "MiniProgramTools",
  "icon": "media/marketplace-icon-128.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mehedi8603651/flutter-mini-program-platform"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "configuration": {
      "title": "MiniProgram",
      "properties": {
        "miniProgram.cliPath": {
          "type": "string",
          "default": "miniprogram",
          "description": "Path or command name for the installed MiniProgram CLI."
        },
        "miniProgram.defaultPreviewDevice": {
          "type": "string",
          "default": "emulator-5554",
          "description": "Default device ID used by MiniProgram: Preview."
        },
        "miniProgram.status.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh local workflow status when the extension activates or the workspace changes."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "miniProgramTools",
          "title": "MiniProgram",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "miniProgramTools": [
        {
          "id": "miniProgramTools.statusView",
          "name": "Status"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "miniProgramTools.statusView",
        "contents": "Open a mini-program or Flutter host app workspace, then refresh status.\n[Refresh Status](command:miniProgramTools.refreshStatus)"
      }
    ],
    "commands": [
      {
        "command": "miniProgramTools.refreshStatus",
        "title": "MiniProgram: Refresh Status",
        "icon": "$(refresh)"
      },
      {
        "command": "miniProgramTools.refreshRemoteStatus",
        "title": "MiniProgram: Refresh Remote Status",
        "icon": "$(cloud)"
      },
      {
        "command": "miniProgramTools.createMiniProgram",
        "title": "MiniProgram: Create MiniProgram",
        "icon": "$(new-folder)"
      },
      {
        "command": "miniProgramTools.build",
        "title": "MiniProgram: Build",
        "icon": "$(tools)"
      },
      {
        "command": "miniProgramTools.validate",
        "title": "MiniProgram: Validate",
        "icon": "$(check)"
      },
      {
        "command": "miniProgramTools.preview",
        "title": "MiniProgram: Preview",
        "icon": "$(device-mobile)"
      },
      {
        "command": "miniProgramTools.publish",
        "title": "MiniProgram: Publish",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "miniProgramTools.publishPublicStaticMiniProgram",
        "title": "MiniProgram: Publish Public Static MiniProgram",
        "icon": "$(globe)"
      },
      {
        "command": "miniProgramTools.embedInit",
        "title": "MiniProgram: Embed Init",
        "icon": "$(package)"
      },
      {
        "command": "miniProgramTools.configureHostCloud",
        "title": "MiniProgram: Configure Host Cloud",
        "icon": "$(cloud)"
      },
      {
        "command": "miniProgramTools.importHostEndpoint",
        "title": "MiniProgram: Import Host Endpoint",
        "icon": "$(cloud-download)"
      },
      {
        "command": "miniProgramTools.addHostEndpoint",
        "title": "MiniProgram: Add Host Endpoint",
        "icon": "$(add)"
      },
      {
        "command": "miniProgramTools.runHostApp",
        "title": "MiniProgram: Run Host App",
        "icon": "$(run)"
      },
      {
        "command": "miniProgramTools.envInit",
        "title": "MiniProgram: Env Init",
        "icon": "$(settings-gear)"
      },
      {
        "command": "miniProgramTools.configureAwsEnvironment",
        "title": "MiniProgram: Configure AWS Environment",
        "icon": "$(cloud)"
      },
      {
        "command": "miniProgramTools.useEnvironment",
        "title": "MiniProgram: Use Environment",
        "icon": "$(checklist)"
      },
      {
        "command": "miniProgramTools.environmentStatus",
        "title": "MiniProgram: Environment Status",
        "icon": "$(info)"
      },
      {
        "command": "miniProgramTools.cloudDeploy",
        "title": "MiniProgram: Cloud Deploy",
        "icon": "$(rocket)"
      },
      {
        "command": "miniProgramTools.cloudStatus",
        "title": "MiniProgram: Cloud Status",
        "icon": "$(cloud)"
      },
      {
        "command": "miniProgramTools.cloudOutputs",
        "title": "MiniProgram: Cloud Outputs",
        "icon": "$(symbol-property)"
      },
      {
        "command": "miniProgramTools.backendInit",
        "title": "MiniProgram: Backend Init",
        "icon": "$(database)"
      },
      {
        "command": "miniProgramTools.backendStart",
        "title": "MiniProgram: Backend Start",
        "icon": "$(debug-start)"
      },
      {
        "command": "miniProgramTools.backendStop",
        "title": "MiniProgram: Backend Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "miniProgramTools.backendStatus",
        "title": "MiniProgram: Backend Status",
        "icon": "$(pulse)"
      },
      {
        "command": "miniProgramTools.publisherBackendSetup",
        "title": "MiniProgram: Setup Publisher Backend",
        "icon": "$(server-process)"
      },
      {
        "command": "miniProgramTools.publisherBackendRun",
        "title": "MiniProgram: Run Publisher Backend",
        "icon": "$(debug-start)"
      },
      {
        "command": "miniProgramTools.publisherBackendStop",
        "title": "MiniProgram: Stop Publisher Backend",
        "icon": "$(debug-stop)"
      },
      {
        "command": "miniProgramTools.publisherBackendStatus",
        "title": "MiniProgram: Publisher Backend Status",
        "icon": "$(pulse)"
      },
      {
        "command": "miniProgramTools.publisherBackendAwsDeploy",
        "title": "MiniProgram: Deploy Publisher Backend to AWS",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "miniProgramTools.publisherBackendAwsStatus",
        "title": "MiniProgram: Publisher Backend AWS Status",
