        "icon": "$(run)"
      },
      {
        "command": "miniProgramTools.generateMiniProgramRegistry",
        "title": "MiniProgram: Generate Host Registry",
        "icon": "$(symbol-constant)"
      },
      {
        "command": "miniProgramTools.addMiniProgramToRegistry",
        "title": "MiniProgram: Add MiniProgram to Registry",
        "icon": "$(list-tree)"
      },
      {
        "command": "miniProgramTools.copyDemoHostButton",
        "title": "MiniProgram: Copy Demo Host Button",
        "icon": "$(copy)"
      },
      {
        "command": "miniProgramTools.insertDemoHostButton",
        "title": "MiniProgram: Copy Demo Host Button",
        "icon": "$(copy)"
      },
      {
        "command": "miniProgramTools.copyWorkflowCommands",
        "title": "MiniProgram: Copy Workflow Commands",
        "icon": "$(copy)"
      },
      {
        "command": "miniProgramTools.checkHostEndpointRemote",
        "title": "MiniProgram: Check Host Endpoint Remote",
        "icon": "$(cloud)"
      },
      {
        "command": "miniProgramTools.copyCleanupCommands",
