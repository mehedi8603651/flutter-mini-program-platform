        "icon": "$(trash)"
      },
      {
        "command": "miniProgramTools.openOutput",
        "title": "MiniProgram: Open Output",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "miniProgramTools.refreshStatus",
          "when": "view == miniProgramTools.statusView",
          "group": "navigation@1"
        },
        {
          "command": "miniProgramTools.refreshRemoteStatus",
