{
  "id": "recharge",
  "version": "1.0.0",
  "entry": "recharge_home",
  "contractVersion": "1.0.0",
  "sdkVersionRange": ">=1.0.0 <2.0.0",
  "screenFormat": "mp",
  "screenSchemaVersion": 1,
  "requiredCapabilities": [
    "analytics"
  ],
  "cachePolicy": {
    "manifest": {
      "mode": "staleWhileError",
      "maxStaleSeconds": 86400
    },
    "entryScreen": {
      "mode": "staleWhileError",
      "maxStaleSeconds": 21600
    }
  },
  "fallback": {
    "strategy": "errorView",
    "message": "Recharge is temporarily unavailable in this host app."
  }
}
